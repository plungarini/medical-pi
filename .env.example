# Medical-pi Configuration
# UI will run on PORT, API will run on PORT+1000
PORT=3003
BASE_STORAGE_PATH=./data
DB_PATH=./data/medical.db

# Modal (MedGemma) Configuration
MODAL_ENDPOINT=
MODAL_MODEL=medgemma-1.5-4b-it
MODAL_API_KEY=

# OpenRouter Configuration
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-flash-lite

# JWT Configuration
JWT_SECRET=
JWT_EXPIRY_DAYS=30

# Meilisearch Configuration
MEILISEARCH_HOST=http://127.0.0.1:7700
MEILISEARCH_DB_PATH=./data/meilisearch

# Profile Configuration
PROFILE_MIN_CONFIDENCE=0.7
CONTEXT_MESSAGE_LIMIT=20

# Heartbeat/Cron Configuration
HEARTBEAT_ENABLED=true
HEARTBEAT_INTERVAL=0 * * * *
TITLE_REPAIR_CRON=0 2 * * *
REINDEX_CRON=0 3 * * *
MEILI_SYNC_CRON=*/15 * * * *

# External Services
MEMORY_PI_ENABLED=true
MEMORY_PI_URL=http://127.0.0.1:3002/api
MEMORY_PI_PROJECT=health
BRAVE_SEARCH_API_KEY=

# Limits
MAX_DOCUMENT_SIZE_MB=25

# Logging
LOGGER_PI_URL=http://127.0.0.1:4000
LOGGER_PI_SERVICE_NAME=medical-pi
