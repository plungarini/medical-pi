{
  "author": "",
  "dependencies": {
    "@ai-sdk/openai": "^3.0.36",
    "@assistant-ui/react": "^0.12.14",
    "@assistant-ui/react-ai-sdk": "^1.3.10",
    "@assistant-ui/react-markdown": "^0.12.5",
    "@fastify/cors": "^10.0.0",
    "@fastify/multipart": "^9.0.0",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.5",
    "@radix-ui/react-label": "^2.1.1",
    "@radix-ui/react-separator": "^1.1.1",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.2",
    "@radix-ui/react-tooltip": "^1.2.8",
    "ai": "^6.0.103",
    "better-sqlite3": "^12.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^16.6.1",
    "fastify": "^5.0.0",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.575.0",
    "next": "16.1.6",
    "next-themes": "^0.4.4",
    "openai": "^4.0.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "remark-gfm": "^4.0.1",
    "sonner": "^1.7.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "tw-shimmer": "^0.4.7",
    "zod": "^3.23.0",
    "zustand": "^5.0.11"
  },
  "description": "Medical AI Assistant powered by MedGemma",
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/better-sqlite3": "^7.6.12",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^9.0.0",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3",
    "vitest": "^2.1.0"
  },
  "keywords": [
    "medical",
    "ai",
    "medgemma",
    "health"
  ],
  "license": "MIT",
  "name": "medical-pi",
  "scripts": {
    "build": "npm run build:server && npm run build:ui",
    "build:server": "tsc -p server/tsconfig.json",
    "build:ui": "cd ui && npm run build",
    "dev": "node scripts/dev-with-meilisearch.js",
    "dev:server": "tsx server/index.ts",
    "dev:ui": "cd ui && npm run dev",
    "format": "biome format .",
    "format:fix": "biome format --write .",
    "install:all": "npm run install:ui && npm run install:server",
    "install:server": "cd server && npm install",
    "install:ui": "cd ui && npm install",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "onboard": "node scripts/onboard.js",
    "postinstall": "npm run install:all",
    "start": "node scripts/start-with-meilisearch.js",
    "start:meilisearch": "node scripts/start-meilisearch.js",
    "start:server": "node server/dist/index.js",
    "start:ui": "cd ui && npm run start",
    "test": "vitest run",
    "test:ui": "cd ui && npm test 2>/dev/null || echo 'No UI tests configured'",
    "test:watch": "vitest",
    "typecheck": "tsc -p server/tsconfig.json --noEmit",
    "typecheck:ui": "cd ui && npm run typecheck 2>/dev/null || echo 'No typecheck in UI'"
  },
  "type": "module",
  "version": "1.6.0"
}
