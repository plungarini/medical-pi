{
  "name": "medical-pi",
  "version": "1.0.0",
  "description": "Medical AI assistant microservice for Raspberry Pi",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && npm run build:ui",
    "build:server": "tsc",
    "build:ui": "vite build --config ui/vite.config.ts",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:ui\"",
    "dev:server": "tsx watch src/index.ts",
    "dev:ui": "vite --config ui/vite.config.ts",
    "start": "node dist/index.js",
    "onboard": "node scripts/onboard.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/jwt": "^9.1.0",
    "@fastify/multipart": "^9.0.3",
    "@fastify/static": "^9.0.0",
    "better-sqlite3": "^12.6.2",
    "clsx": "^2.1.1",
    "dotenv": "^17.3.1",
    "fastify": "^5.8.1",
    "framer-motion": "^12.4.7",
    "lucide-react": "^0.477.0",
    "meilisearch": "^0.49.0",
    "node-cron": "^4.2.1",
    "openai": "^4.90.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.0.2",
    "uuid": "^11.1.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.3.5",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.1.2",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.19.3",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
